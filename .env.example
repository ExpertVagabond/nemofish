# =============================================================
# NemoFish Configuration
# =============================================================
# Swarm Intelligence Prediction Engine powered by NVIDIA NIM
# Get a free NIM API key at https://build.nvidia.com
# =============================================================

# ===== NVIDIA NIM Configuration =====
# Sign up free at build.nvidia.com for an API key
LLM_API_KEY=nvapi-YOUR_KEY_HERE
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL_NAME=nvidia/llama-3.3-nemotron-super-49b-v1

# ===== Embedding Configuration =====
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
EMBEDDING_BASE_URL=https://integrate.api.nvidia.com

# ===== Neo4j Configuration =====
# For Docker: use service name "neo4j" instead of "localhost"
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nemofish

# ===== OASIS / CAMEL-AI Configuration =====
# CAMEL-AI reads OPENAI_API_KEY and OPENAI_API_BASE_URL
# Points to NIM (OpenAI-compatible)
OPENAI_API_KEY=nvapi-YOUR_KEY_HERE
OPENAI_API_BASE_URL=https://integrate.api.nvidia.com/v1

# ===== Simulation Configuration =====
OASIS_DEFAULT_MAX_ROUNDS=10
REPORT_AGENT_MAX_TOOL_CALLS=5
REPORT_AGENT_TEMPERATURE=0.3

# ===== Alternative: Local Ollama =====
# Uncomment to use local Ollama instead of NIM
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL_NAME=qwen2.5:32b
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=ollama
# OPENAI_API_BASE_URL=http://localhost:11434/v1
